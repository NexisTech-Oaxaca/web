# Strapi CMS (used at build time for SSG)
STRAPI_URL=https://your-strapi.example.com
STRAPI_TOKEN=your-strapi-api-token

# Optional public fallbacks (only needed if the client runs in the browser)
# PUBLIC_STRAPI_URL=
# PUBLIC_STRAPI_TOKEN=

# Cloudflare Functions (contact form & member registration - required at runtime)
# Para desarrollo local con `astro dev`: copia estas líneas a un archivo .env
# Para desarrollo con `wrangler`: copia estas líneas a .dev.vars
# Para producción: configúralo en Cloudflare Pages Dashboard > Settings > Environment variables
RESEND_API_KEY=re_xxxxxxxxxxxx

# Turnstile (anti-bot) - secret key for server-side verification
# Debe coincidir con el site key usado en el frontend
TURNSTILE_SECRET_KEY=0x4AAAAAAD6uLyml5OaSHsGS

# Strapi CMS (needed at runtime for member registration in /api/ingreso)
STRAPI_URL=https://your-strapi.example.com
STRAPI_TOKEN=your-strapi-api-token
