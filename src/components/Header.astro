---
import { Zap } from "lucide-astro";
---

<header
  class="fixed top-0 left-0 w-full z-50 bg-marfil/80 backdrop-blur-md border-b border-petroleo/5"
>
  <nav class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    <a href="/" class="flex items-center space-x-2 group">
      <div
        class="w-10 h-10 bg-jade rounded-xl flex items-center justify-center text-white shadow-lg shadow-jade/20 group-hover:scale-110 transition-transform"
      >
        <img
          src="/nexis.svg"
          alt="Nexis Oaxaca"
          class="h-full w-full object-contain"
        />
      </div>
      <span
        class="text-xl font-bold tracking-tight text-petroleo font-display uppercase"
        >NEXIS<span class="text-jade"> OAXACA</span></span
      >
    </a>

    <div class="hidden md:flex items-center space-x-8">
      <a
        href="/"
        class="text-sm font-semibold text-petroleo/70 hover:text-jade transition-colors"
        >Inicio</a
      >
      <a
        href="/eventos"
        class="text-sm font-semibold text-petroleo/70 hover:text-jade transition-colors"
        >Eventos</a
      >
      <a
        href="/proyectos/"
        class="text-sm font-semibold text-petroleo/70 hover:text-jade transition-colors"
        >Proyectos</a
      >
      <a
        href="/emprendimientos"
        class="text-sm font-semibold text-petroleo/70 hover:text-jade transition-colors"
        >Emprendimientos</a
      >
    </div>

    <button
      class="bg-jade text-white px-6 py-2.5 rounded-full font-bold text-sm hover:bg-petroleo transition-all duration-300 shadow-md shadow-jade/10"
    >
      Únete a la comunidad
    </button>
  </nav>
</header>
