---
import { Menu, X } from "lucide-astro";

const pathname = new URL(Astro.url).pathname;
const activePath = pathname === '/' ? '/' : pathname.replace(/\/$/, '');

const navLinks = [
  { href: "/", label: "Inicio" },
  { href: "/eventos", label: "Eventos" },
  { href: "/proyectos/", label: "Proyectos" },
  { href: "/emprendimientos", label: "Emprendimientos" },
  { href: "/contacto", label: "Contacto" }
];
---

<header
  class="fixed top-0 left-0 w-full z-50 bg-marfil/80 backdrop-blur-md border-b border-petroleo/5"
>
  <nav class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    <a href="/" class="flex items-center space-x-2 group" id="header-logo">
      <div
        class="w-10 h-10 bg-jade rounded-xl flex items-center justify-center text-white shadow-lg shadow-jade/20 transition-transform"
      >
        <img
          src="/nexis.svg"
          alt="Nexis Oaxaca"
          class="h-full w-full object-contain"
        />
      </div>
      <span
        class="text-xl font-bold tracking-tight text-petroleo font-display uppercase"
        >NEXIS<span class="text-jade"> OAXACA</span></span
      >
    </a>

    <!-- Desktop Navigation Links -->
    <div class="hidden md:flex items-center space-x-8">
      {
        navLinks.map((link) => {
          const linkPath = link.href.replace(/\/$/, '') || '/';
          const isActive = linkPath === '/' ? activePath === '/' : activePath.startsWith(linkPath);
          return (
            <a
              href={link.href}
              class={`relative text-sm font-semibold py-1.5 transition-colors ${
                isActive ? "text-jade" : "text-petroleo/70 hover:text-jade"
              }`}
            >
              {link.label}
              {isActive && (
                <span
                  class="absolute bottom-0 left-0 right-0 h-[2px] bg-jade rounded-full"
                  transition:name="active-nav-indicator"
                />
              )}
            </a>
          );
        })
      }
    </div>

    <!-- Desktop Join Button -->
    <button
      id="join-community-btn"
      class="hidden md:block bg-jade text-white px-6 py-2.5 rounded-full font-bold text-sm hover:bg-petroleo transition-colors duration-300 shadow-md shadow-jade/10 cursor-pointer"
    >
      Únete a la comunidad
    </button>

    <!-- Hamburger Menu Toggle Button (Mobile Only) -->
    <button
      id="mobile-menu-toggle"
      class="block md:hidden text-petroleo hover:text-jade p-2 transition-colors focus:outline-none cursor-pointer"
      aria-label="Toggle Menu"
    >
      <Menu id="menu-icon" class="w-6 h-6" />
      <X id="close-icon" class="w-6 h-6 hidden" />
    </button>
  </nav>

  <!-- Mobile Menu Drawer (Overlay) -->
  <div
    id="mobile-menu"
    class="fixed top-20 left-0 w-full h-[calc(100vh-5rem)] bg-marfil/95 backdrop-blur-lg border-b border-petroleo/5 z-40 transform -translate-y-full opacity-0 pointer-events-none transition-all duration-300 ease-in-out md:hidden flex flex-col justify-between p-8"
  >
    <div class="flex flex-col space-y-6">
      {
        navLinks.map((link) => {
          const linkPath = link.href.replace(/\/$/, '') || '/';
          const isActive = linkPath === '/' ? activePath === '/' : activePath.startsWith(linkPath);
          return (
            <a
              href={link.href}
              class={`mobile-nav-link text-xl font-bold py-3 border-b border-petroleo/5 transition-colors block ${
                isActive ? "text-jade" : "text-petroleo/70 hover:text-jade"
              }`}
            >
              {link.label}
            </a>
          );
        })
      }
    </div>

    <div class="pt-6 border-t border-petroleo/10">
      <button
        id="join-community-btn-mobile"
        class="w-full bg-jade text-white py-3.5 rounded-full font-bold text-base hover:bg-petroleo transition-colors duration-300 shadow-md shadow-jade/10 cursor-pointer text-center block"
      >
        Únete a la comunidad
      </button>
    </div>
  </div>
</header>

<script>
  import { animate, stagger } from "motion";

  const initHeaderInteractions = () => {
    // Reset body scroll on page load
    document.body.style.overflow = "";

    const btn = document.getElementById("join-community-btn");
    if (btn) {
      btn.addEventListener("mouseenter", () => {
        animate(btn, { scale: 1.05, y: -2 }, { type: "spring", stiffness: 400, damping: 15 });
      });
      btn.addEventListener("mouseleave", () => {
        animate(btn, { scale: 1, y: 0 }, { type: "spring", stiffness: 400, damping: 15 });
      });
    }

    const mobileBtn = document.getElementById("join-community-btn-mobile");
    if (mobileBtn) {
      mobileBtn.addEventListener("mouseenter", () => {
        animate(mobileBtn, { scale: 1.02, y: -1 }, { type: "spring", stiffness: 400, damping: 15 });
      });
      mobileBtn.addEventListener("mouseleave", () => {
        animate(mobileBtn, { scale: 1, y: 0 }, { type: "spring", stiffness: 400, damping: 15 });
      });
    }

    const logo = document.getElementById("header-logo");
    if (logo) {
      const logoIcon = logo.querySelector("div");
      if (logoIcon) {
        logo.addEventListener("mouseenter", () => {
          animate(logoIcon, { scale: 1.15, rotate: 5 }, { type: "spring", stiffness: 300, damping: 12 });
        });
        logo.addEventListener("mouseleave", () => {
          animate(logoIcon, { scale: 1, rotate: 0 }, { type: "spring", stiffness: 300, damping: 12 });
        });
      }
    }

    // Mobile Menu logic
    const toggleBtn = document.getElementById("mobile-menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");
    const menuIcon = document.getElementById("menu-icon");
    const closeIcon = document.getElementById("close-icon");
    const mobileMenuLinks = document.querySelectorAll(".mobile-nav-link");

    if (toggleBtn && mobileMenu && menuIcon && closeIcon) {
      let isOpen = false;

      const toggleMenu = () => {
        isOpen = !isOpen;

        if (isOpen) {
          // Open menu
          mobileMenu.classList.remove("-translate-y-full", "opacity-0", "pointer-events-none");
          mobileMenu.classList.add("translate-y-0", "opacity-100", "pointer-events-auto");
          menuIcon.classList.add("hidden");
          closeIcon.classList.remove("hidden");
          document.body.style.overflow = "hidden";

          // Stagger-animate links & button inside mobile menu
          animate(
            mobileMenuLinks,
            { opacity: [0, 1], x: [-20, 0] },
            { delay: stagger(0.05), duration: 0.3 }
          );
          if (mobileBtn) {
            animate(
              mobileBtn,
              { opacity: [0, 1], y: [10, 0] },
              { delay: 0.2, duration: 0.3 }
            );
          }
        } else {
          // Close menu
          mobileMenu.classList.add("-translate-y-full", "opacity-0", "pointer-events-none");
          mobileMenu.classList.remove("translate-y-0", "opacity-100", "pointer-events-auto");
          menuIcon.classList.remove("hidden");
          closeIcon.classList.add("hidden");
          document.body.style.overflow = "";
        }
      };

      toggleBtn.addEventListener("click", toggleMenu);

      // Close menu when clicking a link
      mobileMenuLinks.forEach((link) => {
        link.addEventListener("click", () => {
          if (isOpen) toggleMenu();
        });
      });
    }
  };

  document.addEventListener("astro:page-load", initHeaderInteractions);
</script>

