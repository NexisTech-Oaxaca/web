---
import { Linkedin, Twitter, Github, Globe, Instagram } from 'lucide-astro';
import type { TeamMember } from '../lib/cms';

interface Props {
  members: TeamMember[];
}

const { members } = Astro.props as Props;
---

<section class="py-32 px-6 bg-arena overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-20 reveal">
       <h2 class="text-4xl font-bold text-petroleo font-display">Equipo Organizador</h2>
       <p class="text-petroleo/60 mt-2">Los rostros detrás de la comunidad.</p>
    </div>
    
    <div class="flex gap-8 overflow-x-auto pb-12 snap-x snap-mandatory scrollbar-hidden reveal">
      {members.map((member, index) => (
        <div class="flex-none w-72 text-center group snap-center" style={`transition-delay: ${index * 100}ms`}>
          <div class="relative w-48 h-48 mx-auto mb-8">
            <div class={`absolute inset-0 ${member.color} rounded-[40px] rotate-6 group-hover:rotate-12 transition-transform duration-500 shadow-lg shadow-black/5`}></div>
            <img 
              src={member.image} 
              alt={member.name} 
              class="relative z-10 w-full h-full object-cover rounded-[40px] border-4 border-white shadow-xl grayscale group-hover:grayscale-0 transition-all duration-500" 
            />
          </div>
          <h4 class="text-xl font-bold text-petroleo font-display">{member.name}</h4>
          <p class="text-[10px] text-jade font-bold uppercase tracking-widest mb-4">{member.role}</p>
          <div class="flex justify-center space-x-4 text-petroleo/30">
            {Object.entries(member.social).map(([key, url]) => (
              <a href={url} class="hover:text-jade transition-colors">
                {key === 'linkedin' && <Linkedin class="w-4 h-4" />}
                {key === 'twitter' && <Twitter class="w-4 h-4" />}
                {key === 'github' && <Github class="w-4 h-4" />}
                {key === 'globe' && <Globe class="w-4 h-4" />}
                {key === 'instagram' && <Instagram class="w-4 h-4" />}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-hidden::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hidden {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
