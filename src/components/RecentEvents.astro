---
import events from '../data/events.json';
import { ArrowRight } from 'lucide-astro';

const recentEvents = events.slice(0, 4);
---

<section class="py-32 px-6 bg-marfil">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6 reveal">
      <div>
        <h2 class="text-4xl font-bold text-petroleo">Eventos Recientes</h2>
        <p class="text-petroleo/60 mt-2">Momentos que definieron nuestra comunidad este último mes.</p>
      </div>
      <a href="/eventos" class="text-jade font-bold flex items-center group">
        Ver cartelera completa <ArrowRight class="ml-2 group-hover:translate-x-2 transition-transform" />
      </a>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {recentEvents.map((event, index) => (
        <div class="reveal group event-card" style={`transition-delay: ${index * 100}ms`}>
          <div class="aspect-[4/5] rounded-[32px] overflow-hidden mb-6 relative bg-petroleo/5 shadow-sm group-hover:shadow-xl transition-all duration-500">
            <img 
              src={event.image} 
              alt={event.title} 
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
            />
            <div class="absolute inset-0 bg-gradient-to-t from-petroleo/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute bottom-6 left-6 right-6 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-4 group-hover:translate-y-0">
               <a href={`/eventos/${event.id}`} class="w-full block text-center py-3 bg-white text-petroleo rounded-xl font-bold text-sm hover:bg-jade hover:text-white transition-colors">
                 Ver Resumen
               </a>
            </div>
          </div>
          <div class="flex items-center space-x-3 text-xs font-bold text-jade uppercase tracking-widest mb-2">
            <span>{event.type || 'Evento'}</span>
            <span class="w-1 h-1 rounded-full bg-ambar"></span>
            <span>{new Date(event.date).toLocaleDateString('es-ES', { day: 'numeric', month: 'long' })}</span>
          </div>
          <h3 class="text-xl font-bold text-petroleo mb-2 group-hover:text-jade transition-colors">{event.title}</h3>
          <p class="text-sm text-petroleo/60 line-clamp-2 leading-relaxed">{event.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
