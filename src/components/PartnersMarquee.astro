---
const partners = [
  "UNIVERSIDAD DEL ISTMO",
  "UDEV-IT",
];
---

<section class="py-20 bg-arena border-y border-petroleo/5 overflow-hidden">
  <div class="flex whitespace-nowrap animate-marquee">
    <div class="flex space-x-24 items-center px-12">
      {partners.map(p => (
        <span class="text-2xl font-bold font-display text-petroleo/60 hover:text-jade transition-colors cursor-default">{p}</span>
      ))}
      {partners.map(p => (
        <span class="text-2xl font-bold font-display text-petroleo/60 hover:text-jade transition-colors cursor-default">{p}</span>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee {
    animation: marquee 4s linear infinite;
  }
  @media (min-width: 768px) {
    .animate-marquee {
      animation-duration: 30s;
    }
  }
  @media (min-width: 1024px) {
    .animate-marquee {
      animation-duration: 40s;
    }
  }
  .animate-marquee:hover {
    animation-play-state: paused;
  }
</style>
