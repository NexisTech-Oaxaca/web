---
import { Rocket } from "lucide-astro";
---

<div
  class="reveal group bg-petroleo rounded-[40px] p-10 border border-petroleo shadow-2xl hover:bg-jade transition-all duration-500 relative flex flex-col items-center justify-center text-center overflow-hidden min-h-[480px]"
>
  <div class="mitla-pattern absolute inset-0 opacity-10"></div>
  <div class="relative z-10">
    <div
      class="w-24 h-24 bg-white/10 rounded-full flex items-center justify-center text-white mb-8 mx-auto group-hover:scale-110 transition-transform ring-4 ring-white/5"
    >
      <Rocket class="w-10 h-10" />
    </div>
    <h3
      class="font-display text-3xl text-white mb-6 font-bold uppercase tracking-tight"
    >
      ¿Tu startup no está aquí?
    </h3>
    <p
      class="text-white/60 text-sm mb-12 leading-relaxed max-w-[260px] mx-auto font-medium"
    >
      Únete al directorio oficial de la comunidad y conecta con talento e
      inversionistas globales.
    </p>
    <button
      class="w-full py-5 bg-white text-petroleo rounded-2xl text-xs font-black uppercase tracking-[0.2em] hover:bg-marfil transition-colors shadow-lg"
    >
      Postular Ahora
    </button>
  </div>
</div>
