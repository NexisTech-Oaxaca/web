---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getProjects } from "../../lib/cms";
import { ArrowRight } from "lucide-astro";

const projects = await getProjects();
---

<Layout title="Proyectos Comunitarios | Nexis Oaxaca Tech" description="Explora las iniciativas de hardware libre, inteligencia artificial y software open source creadas por la comunidad de Nexis en Oaxaca.">
  <Header />

  <main class="pt-40 pb-24 px-6 bg-marfil">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16 text-left">
        <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-jade/10 text-petroleo text-[10px] font-black uppercase tracking-[0.2em] mb-6 border border-jade/20 shadow-sm">
          Repositorio abierto
        </div>
        <h1 class="text-4xl sm:text-5xl md:text-7xl font-extrabold font-display leading-[0.95] tracking-tight uppercase text-petroleo">
          Proyectos <span class="text-jade">Comunitarios</span>
        </h1>
        <p class="text-sm sm:text-base md:text-xl text-petroleo/85 max-w-2xl mt-6 leading-relaxed">
          Explora las iniciativas de hardware libre, inteligencia artificial y software open source creadas por la comunidad de Nexis en Oaxaca.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((project) => (
          <article class="bg-white rounded-4xl overflow-hidden shadow-lg border border-petroleo/5 hover:shadow-2xl transition-shadow duration-300 flex flex-col group text-left">
            <div class="relative overflow-hidden h-64">
              <img
                src={project.image}
                alt={project.name}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-linear-to-t from-petroleo/60 to-transparent"></div>
              <div class="absolute bottom-6 left-6">
                <span class={`px-4 py-1.5 rounded-full text-[9px] font-black uppercase tracking-wider text-white ${project.status === "ACTIVO" ? "bg-jade" : project.status === "EN DESARROLLO" ? "bg-ambar" : "bg-petroleo/60"}`}>
                  {project.status}
                </span>
              </div>
            </div>

            <div class="p-8 flex flex-col grow space-y-6">
              <div class="flex flex-wrap gap-2">
                {project.tags.slice(0, 3).map((tag) => (
                  <span class="text-[9px] font-bold text-jade/80 tracking-wide uppercase">
                    {tag}
                  </span>
                ))}
              </div>

              <div class="space-y-3">
                <h2 class="text-2xl font-bold font-display text-petroleo leading-tight group-hover:text-jade transition-colors uppercase">
                  {project.name}
                </h2>
                <p class="text-sm text-petroleo/75 leading-relaxed font-medium line-clamp-3">
                  {project.description}
                </p>
              </div>

              <a
                href={`/proyectos/${project.slug}`}
                class="inline-flex items-center justify-between w-full border border-petroleo/10 hover:border-jade text-petroleo hover:text-jade font-bold text-xs uppercase tracking-widest px-6 py-4 rounded-2xl transition-all"
              >
                <span>Ver proyecto</span>
                <ArrowRight class="w-4 h-4" />
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>