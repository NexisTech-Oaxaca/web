---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getStartupBySlug, getStartups } from "../../lib/cms";
import { ArrowLeft, ArrowRight, Github, Linkedin, Twitter, Globe, ExternalLink } from "lucide-astro";

export async function getStaticPaths() {
  const startups = await getStartups();

  return startups.map((startup) => ({
    params: { id: startup.slug },
    props: { startup },
  }));
}

const { startup: staticStartup } = Astro.props;
const startup = staticStartup ?? (await getStartupBySlug(Astro.params.id || ""));

if (!startup) {
  throw new Error(`Emprendimiento no encontrado: ${Astro.params.id}`);
}
---

<Layout title={`${startup.name} | Nexis Emprendimientos`} description={startup.tagline || startup.description}>
  <Header />

  <main class="bg-marfil pt-40 pb-24">
    <div class="max-w-7xl mx-auto px-6 space-y-24">
      <a href="/emprendimientos" class="inline-flex items-center gap-2 text-petroleo/60 hover:text-jade font-bold text-xs uppercase tracking-widest transition-colors group">
        <ArrowLeft class="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
        Volver a emprendimientos
      </a>

      <section class="grid lg:grid-cols-12 gap-16 items-start">
        <div class="lg:col-span-7 space-y-8 text-left">
          <div class="inline-flex items-center gap-4 px-5 py-2 rounded-full bg-jade/10 text-petroleo text-[10px] font-black uppercase tracking-[0.2em] border border-jade/20 shadow-sm">
            {startup.industry} • Startup de la comunidad
          </div>

          <h1 class="text-3xl sm:text-4xl md:text-8xl font-extrabold font-display leading-[0.9] tracking-tighter uppercase text-petroleo">
            {startup.name}
          </h1>

          <p class="text-sm sm:text-base md:text-xl text-petroleo/85 max-w-2xl leading-relaxed font-medium">
            {startup.tagline}
          </p>

          <div class="flex flex-wrap gap-3">
            {startup.website && (
              <a href={startup.website} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-white border border-petroleo/10 text-petroleo text-xs font-black uppercase tracking-widest shadow-sm hover:border-jade hover:text-jade transition-all">
                <Globe class="w-4 h-4" /> Sitio web <ExternalLink class="w-3 h-3" />
              </a>
            )}
            {startup.socials.linkedin && (
              <a href={startup.socials.linkedin} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-white border border-petroleo/10 text-petroleo text-xs font-black uppercase tracking-widest shadow-sm hover:border-jade hover:text-jade transition-all">
                <Linkedin class="w-4 h-4 text-[#0A66C2]" /> LinkedIn
              </a>
            )}
            {startup.socials.twitter && (
              <a href={startup.socials.twitter} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-white border border-petroleo/10 text-petroleo text-xs font-black uppercase tracking-widest shadow-sm hover:border-jade hover:text-jade transition-all">
                <Twitter class="w-4 h-4 text-[#1DA1F2]" /> Twitter
              </a>
            )}
            {startup.socials.github && (
              <a href={startup.socials.github} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-white border border-petroleo/10 text-petroleo text-xs font-black uppercase tracking-widest shadow-sm hover:border-jade hover:text-jade transition-all">
                <Github class="w-4 h-4" /> GitHub
              </a>
            )}
          </div>
        </div>

        <div class="lg:col-span-5">
          <div class="relative w-full rounded-[40px] overflow-hidden shadow-2xl aspect-video border-8 border-white">
            <img src={startup.banner} alt={startup.name} class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-linear-to-t from-petroleo/80 via-transparent to-transparent opacity-60"></div>
          </div>
        </div>
      </section>

      <section class="grid lg:grid-cols-12 gap-16">
        <div class="lg:col-span-5 bg-petroleo text-white rounded-[40px] p-10 md:p-14 text-left space-y-8">
          <h2 class="text-3xl sm:text-4xl font-bold font-display uppercase tracking-tight">
            Misión & enfoque
          </h2>
          <p class="text-white/80 text-xl sm:text-2xl font-display leading-relaxed">
            {startup.description}
          </p>

          <div class="space-y-6 text-white/70 text-base leading-relaxed">
            <div>
              <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-jade mb-3">Qué hacemos</h3>
              <p>{startup.details.whatWeDo}</p>
            </div>
            <div>
              <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-jade mb-3">Mercado & impacto</h3>
              <p>{startup.details.market}</p>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-6 pt-6 border-t border-white/10">
            {startup.details.stats.map((stat) => (
              <div>
                <p class="text-4xl font-extrabold font-display text-jade mb-1">{stat.value}</p>
                <p class="text-[10px] text-white/60 font-black uppercase tracking-[0.2em]">{stat.label}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="lg:col-span-7 bg-white rounded-[40px] p-10 md:p-14 text-left border border-petroleo/5 shadow-sm space-y-8">
          <h2 class="text-3xl sm:text-4xl font-bold font-display uppercase tracking-tight text-petroleo">
            Equipo fundador
          </h2>

          <div class="grid md:grid-cols-2 gap-6">
            {startup.team.map((member) => (
              <article class="rounded-3xl border border-petroleo/5 overflow-hidden bg-marfil">
                <img src={member.image} alt={member.name} class="w-full h-52 object-cover" />
                <div class="p-6 space-y-3">
                  <h3 class="text-xl font-bold font-display text-petroleo uppercase">{member.name}</h3>
                  <p class="text-jade text-[10px] font-black uppercase tracking-[0.2em]">{member.role}</p>
                  <p class="text-sm text-petroleo/75 leading-relaxed">{member.description}</p>
                  <div class="flex gap-4 pt-4 border-t border-petroleo/5">
                    {Object.entries(member.links).map(([key, url]) => (
                      <a href={url} class="text-petroleo/50 hover:text-jade transition-colors" target="_blank" rel="noreferrer">
                        {key === 'linkedin' && <Linkedin class="w-4 h-4" />}
                        {key === 'github' && <Github class="w-4 h-4" />}
                        {key === 'globe' && <Globe class="w-4 h-4" />}
                        {key === 'external' && <ArrowRight class="w-4 h-4" />}
                      </a>
                    ))}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="grid lg:grid-cols-12 gap-16">
        <div class="lg:col-span-5 bg-arena rounded-[40px] p-10 text-left border border-petroleo/5">
          <h2 class="text-3xl sm:text-4xl font-bold font-display uppercase tracking-tight text-petroleo mb-8">
            Línea de tiempo
          </h2>
          <div class="space-y-8">
            {startup.timeline.map((item, index) => (
              <div class="relative pl-10">
                <div class="absolute left-0 top-1 w-5 h-5 rounded-full bg-jade"></div>
                <h3 class="text-xl font-bold font-display text-petroleo uppercase">{item.title}</h3>
                <p class="text-[10px] font-black uppercase tracking-[0.2em] text-jade mt-1">{item.date}</p>
                <p class="text-sm text-petroleo/75 leading-relaxed mt-3">{item.description}</p>
                {index !== startup.timeline.length - 1 && <div class="absolute left-2.25 top-5 -bottom-8 w-px bg-jade/30"></div>}
              </div>
            ))}
          </div>
        </div>

        <div class="lg:col-span-7 bg-white rounded-[40px] p-10 text-left border border-petroleo/5 shadow-sm">
          <h2 class="text-3xl sm:text-4xl font-bold font-display uppercase tracking-tight text-petroleo mb-8">
            Evidencias & operación
          </h2>

          <div class="grid sm:grid-cols-2 gap-6">
            {startup.evidence.map((item) => (
              <figure class="rounded-3xl overflow-hidden border border-petroleo/5 bg-marfil">
                <img src={item.image} alt={item.title} class="w-full h-56 object-cover" />
                <figcaption class="p-5">
                  <p class="text-[10px] font-black uppercase tracking-[0.2em] text-jade mb-2">{item.type}</p>
                  <h3 class="text-lg font-bold text-petroleo">{item.title}</h3>
                </figcaption>
              </figure>
            ))}
          </div>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</Layout>