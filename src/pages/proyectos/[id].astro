---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getProjectBySlug, getProjects } from '../../lib/cms';
import { ArrowLeft, ArrowRight, Github, Linkedin, ExternalLink, Globe } from 'lucide-astro';

export async function getStaticPaths() {
  const projects = await getProjects();

  return projects.map((project) => ({
    params: { id: project.slug },
    props: { project },
  }));
}

const { project: staticProject } = Astro.props;
const project = staticProject ?? (await getProjectBySlug(Astro.params.id || ''));

if (!project) {
  throw new Error(`Proyecto no encontrado: ${Astro.params.id}`);
}
---

<Layout title={`${project.name} | Nexis Projects`}>
  <Header />

  <main class="bg-marfil pt-40 pb-24">
    <div class="max-w-7xl mx-auto px-6 space-y-24">
      <a href="/proyectos" class="inline-flex items-center gap-2 text-petroleo/40 hover:text-jade font-bold text-xs uppercase tracking-widest transition-colors group">
        <ArrowLeft class="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
        Volver a proyectos
      </a>

      <section class="grid lg:grid-cols-12 gap-16 items-start">
        <div class="lg:col-span-7 space-y-8 text-left">
          <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-jade/10 text-jade text-[10px] font-black uppercase tracking-[0.2em] border border-jade/20 shadow-sm">
            Proyecto comunitario • {project.status}
          </div>

          <h1 class="text-3xl sm:text-4xl md:text-8xl font-extrabold font-display leading-[0.9] tracking-tighter uppercase text-petroleo">
            {project.name}
          </h1>

          <p class="text-sm sm:text-base md:text-xl text-petroleo/70 max-w-2xl leading-relaxed font-medium">
            {project.description}
          </p>

          <div class="flex flex-wrap gap-3">
            {project.tags.map((tag) => (
              <span class="px-4 py-2 rounded-full bg-white border border-petroleo/5 text-petroleo text-[10px] font-black uppercase tracking-widest shadow-sm">
                {tag}
              </span>
            ))}
          </div>
        </div>

        <div class="lg:col-span-5">
          <div class="relative w-full rounded-[40px] overflow-hidden shadow-2xl aspect-video border-8 border-white">
            <img src={project.image} alt={project.name} class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-linear-to-t from-petroleo/80 via-transparent to-transparent opacity-60"></div>
          </div>
        </div>
      </section>

      <section class="grid lg:grid-cols-2 gap-16">
        <div class="bg-petroleo text-white rounded-[40px] p-10 md:p-14 text-left space-y-8">
          <h2 class="text-3xl sm:text-4xl font-bold font-display uppercase tracking-tight">
            El desafío
          </h2>
          <p class="text-white/70 text-sm sm:text-base md:text-lg leading-relaxed whitespace-pre-line">
            {project.challenge.title}
            {'\n\n'}
            {project.challenge.description}
          </p>

          <div class="grid grid-cols-2 gap-6">
            {project.challenge.stats.map((stat) => (
              <div>
                <p class="text-4xl font-extrabold font-display text-jade mb-1">{stat.value}</p>
                <p class="text-[10px] text-white/40 font-black uppercase tracking-[0.2em]">{stat.label}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="bg-white rounded-[40px] p-10 md:p-14 text-left space-y-8 border border-petroleo/5 shadow-sm">
          <h2 class="text-3xl sm:text-4xl font-bold font-display uppercase tracking-tight text-petroleo">
            Equipo núcleo
          </h2>

          <div class="grid md:grid-cols-2 gap-6">
            {project.team.map((member) => (
              <article class="rounded-3xl border border-petroleo/5 overflow-hidden bg-marfil">
                <img src={member.image} alt={member.name} class="w-full h-52 object-cover" />
                <div class="p-6 space-y-3">
                  <h3 class="text-xl font-bold font-display text-petroleo uppercase">{member.name}</h3>
                  <p class="text-jade text-[10px] font-black uppercase tracking-[0.2em]">{member.role}</p>
                  <p class="text-sm text-petroleo/60 leading-relaxed">{member.description}</p>
                  <div class="flex gap-4 pt-4 border-t border-petroleo/5">
                    {Object.entries(member.links).map(([key, url]) => (
                      <a href={url} class="text-petroleo/30 hover:text-jade transition-colors" target="_blank" rel="noreferrer">
                        {key === 'linkedin' && <Linkedin class="w-4 h-4" />}
                        {key === 'github' && <Github class="w-4 h-4" />}
                        {key === 'external' && <ExternalLink class="w-4 h-4" />}
                        {key === 'globe' && <Globe class="w-4 h-4" />}
                      </a>
                    ))}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="grid lg:grid-cols-12 gap-16">
        <div class="lg:col-span-5 bg-arena rounded-[40px] p-10 text-left border border-petroleo/5">
          <h2 class="text-3xl sm:text-4xl font-bold font-display uppercase tracking-tight text-petroleo mb-8">
            Línea de tiempo
          </h2>
          <div class="space-y-8">
            {project.timeline.map((item, index) => (
              <div class="relative pl-10">
                <div class="absolute left-0 top-1 w-5 h-5 rounded-full bg-jade"></div>
                <h3 class="text-xl font-bold font-display text-petroleo uppercase">{item.title}</h3>
                <p class="text-[10px] font-black uppercase tracking-[0.2em] text-jade mt-1">{item.date}</p>
                <p class="text-sm text-petroleo/60 leading-relaxed mt-3">{item.description}</p>
                {index !== project.timeline.length - 1 && <div class="absolute left-2.25 top-5 -bottom-8 w-px bg-jade/30"></div>}
              </div>
            ))}
          </div>
        </div>

        <div class="lg:col-span-7 bg-white rounded-[40px] p-10 text-left border border-petroleo/5 shadow-sm">
          <h2 class="text-3xl sm:text-4xl font-bold font-display uppercase tracking-tight text-petroleo mb-8">
            Evidencias del progreso
          </h2>
          <div class="grid sm:grid-cols-2 gap-6">
            {project.evidence.map((item) => (
              <figure class="rounded-3xl overflow-hidden border border-petroleo/5 bg-marfil">
                <img src={item.image} alt={item.title} class="w-full h-56 object-cover" />
                <figcaption class="p-5">
                  <p class="text-[10px] font-black uppercase tracking-[0.2em] text-jade mb-2">{item.type}</p>
                  <h3 class="text-lg font-bold text-petroleo">{item.title}</h3>
                </figcaption>
              </figure>
            ))}
          </div>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</Layout>