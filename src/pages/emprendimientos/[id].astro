---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import startups from "../../data/startups.json";
import TeamMemberCard from "../../components/TeamMemberCard.astro";
import { Github, Linkedin, Twitter, Globe, ArrowRight, ArrowLeft, ExternalLink } from "lucide-astro";

export function getStaticPaths() {
  return startups.map(startup => ({
    params: { id: startup.id },
    props: { startup }
  }));
}

const { startup } = Astro.props;

// Safe splitting for headers to maintain the premium design layout
const nameHasOaxaca = startup.name.toLowerCase().includes("oaxaca");
const namePart1 = nameHasOaxaca ? startup.name.split(/oaxaca/i)[0] : startup.name;
const namePart2 = nameHasOaxaca ? startup.name.split(/oaxaca/i)[1] : "";
---

<Layout title={`${startup.name} | Nexis Emprendimientos`}>
  <Header />

  <main class="opacity-0 transition-opacity duration-1000 bg-marfil" id="main-content">
    <!-- Hero Section -->
    <section class="pt-40 pb-24 px-6 relative overflow-hidden reveal">
      <div class="mitla-pattern absolute inset-0 -z-10 opacity-30"></div>
      <div class="max-w-7xl mx-auto flex flex-col items-center text-center">
        <!-- Back Link -->
        <a href="/emprendimientos" class="inline-flex items-center gap-2 text-petroleo/40 hover:text-jade font-bold text-xs uppercase tracking-widest mb-12 transition-colors group self-start">
          <ArrowLeft class="w-4 h-4 group-hover:-translate-x-1 transition-transform" /> Volver a emprendimientos
        </a>

        <!-- Status & Category Pill -->
        <div class="inline-flex items-center gap-4 px-5 py-2 rounded-full bg-jade/10 text-jade text-[10px] font-black uppercase tracking-[0.2em] mb-12 border border-jade/20 shadow-sm">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-jade opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-jade"></span>
          </span>
          {startup.industry} • STARTUP DE LA COMUNIDAD
        </div>
        
        <!-- Big Brand Title -->
        <h1 class="text-5xl md:text-8xl font-extrabold font-display leading-[0.9] tracking-tighter mb-10 max-w-5xl uppercase text-petroleo" transition:name={`startup-name-${startup.id}`}>
          {namePart1}<br />
          {nameHasOaxaca && (
            <span class="text-jade">Oaxaca {namePart2}</span>
          )}
        </h1>
        
        <!-- Tagline -->
        <p class="text-lg md:text-xl text-petroleo/70 max-w-2xl leading-relaxed mb-16 font-medium">
          {startup.tagline}
        </p>

        <!-- Social Media / Primary Website Links -->
        <div class="flex flex-wrap justify-center gap-6 mb-24">
          {startup.website && (
            <a href={startup.website} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-white border border-petroleo/10 text-petroleo text-xs font-black uppercase tracking-widest shadow-sm hover:border-jade hover:text-jade transition-all">
              <Globe class="w-4 h-4" /> Sitio Web <ExternalLink class="w-3 h-3" />
            </a>
          )}
          {startup.socials.linkedin && (
            <a href={startup.socials.linkedin} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-white border border-petroleo/10 text-petroleo text-xs font-black uppercase tracking-widest shadow-sm hover:border-jade hover:text-jade transition-all">
              <Linkedin class="w-4 h-4 text-[#0A66C2]" /> LinkedIn
            </a>
          )}
          {startup.socials.twitter && (
            <a href={startup.socials.twitter} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-white border border-petroleo/10 text-petroleo text-xs font-black uppercase tracking-widest shadow-sm hover:border-jade hover:text-jade transition-all">
              <Twitter class="w-4 h-4 text-[#1DA1F2]" /> Twitter
            </a>
          )}
          {startup.socials.github && (
            <a href={startup.socials.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-white border border-petroleo/10 text-petroleo text-xs font-black uppercase tracking-widest shadow-sm hover:border-jade hover:text-jade transition-all">
              <Github class="w-4 h-4" /> GitHub
            </a>
          )}
        </div>

        <!-- Banner image -->
        <div class="relative w-full max-w-6xl aspect-video rounded-[48px] overflow-hidden shadow-3xl border-[12px] border-white group">
          <div class="absolute inset-0 bg-gradient-to-t from-petroleo/80 via-transparent to-transparent z-10 opacity-60"></div>
          <img src={startup.banner} alt={startup.name} class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" transition:name={`startup-banner-${startup.id}`} />
          <div class="absolute bottom-12 left-12 z-20 text-white text-left">
            <p class="text-[10px] font-black text-jade mb-3 uppercase tracking-[0.3em]">Emprendimiento Local</p>
            <h3 class="text-4xl font-display font-bold uppercase tracking-tight">{startup.name}</h3>
          </div>
        </div>
      </div>
    </section>

    <!-- Propósito & Negocio Section -->
    <section class="py-32 bg-petroleo text-white relative overflow-hidden reveal">
      <div class="mitla-pattern absolute inset-0 opacity-5"></div>
      <div class="circuit-line top-0 left-0 opacity-10"></div>
      <div class="max-w-4xl mx-auto px-6 relative z-10 text-left">
        <h2 class="text-4xl md:text-6xl font-bold font-display leading-tight mb-12 uppercase tracking-tight">
          Nuestra <span class="text-jade">Misión & Enfoque</span>
        </h2>
        
        <div class="space-y-10 text-white/70 text-lg md:text-xl leading-relaxed font-medium">
          <p class="text-white text-2xl md:text-3xl font-display font-light leading-relaxed mb-6">
            {startup.description}
          </p>
          <div class="h-px bg-white/10 my-8"></div>
          <div class="grid md:grid-cols-2 gap-12 text-base">
            <div>
              <h4 class="text-xs font-black uppercase text-jade tracking-[0.2em] mb-4">¿Qué Hacemos?</h4>
              <p class="leading-relaxed">{startup.details.whatWeDo}</p>
            </div>
            <div>
              <h4 class="text-xs font-black uppercase text-jade tracking-[0.2em] mb-4">Mercado & Impacto</h4>
              <p class="leading-relaxed">{startup.details.market}</p>
            </div>
          </div>
        </div>

        <!-- Stats Grid -->
        <div class="mt-20 pt-16 border-t border-white/10 grid grid-cols-2 md:grid-cols-3 gap-8">
          {startup.details.stats.map(stat => (
            <div class="text-left">
              <p class="text-5xl md:text-6xl font-extrabold font-display text-jade mb-2">{stat.value}</p>
              <p class="text-[10px] text-white/40 font-black uppercase tracking-[0.2em]">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="circuit-line bottom-0 left-0 opacity-10"></div>
    </section>

    <!-- Team / Founders Section -->
    <section class="py-32 bg-marfil px-6 reveal">
      <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-24 gap-10">
          <div class="text-left">
            <h2 class="text-4xl md:text-5xl font-bold font-display mb-6 text-petroleo uppercase tracking-tight">Equipo Fundador</h2>
            <p class="text-petroleo/50 max-w-xl text-lg font-medium leading-relaxed">Emprendedores y desarrolladores comprometidos con la innovación tecnológica local.</p>
          </div>
          <a href="/#contacto" class="inline-flex items-center gap-3 text-jade font-black text-xs uppercase tracking-widest hover:gap-6 transition-all group bg-white px-8 py-4 rounded-full shadow-sm border border-petroleo/5">
            Conectar con ellos <ArrowRight class="w-5 h-5 group-hover:scale-110 transition-transform" />
          </a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
          {startup.team.map((member, index) => (
            <TeamMemberCard member={member} index={index} />
          ))}
        </div>
      </div>
    </section>

    <!-- Timeline & Evidence Section -->
    <section class="py-40 bg-arena px-6 relative overflow-hidden reveal">
      <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-32">
        <!-- Milestones Timeline -->
        <div class="lg:col-span-5 text-left">
          <div class="mb-20">
            <h2 class="text-4xl font-bold font-display mb-6 text-petroleo uppercase tracking-tight">Milestones</h2>
            <p class="text-petroleo/50 font-medium text-lg leading-relaxed">Nuestra historia de crecimiento y metas alcanzadas.</p>
          </div>
          <div class="space-y-16 relative">
            {startup.timeline.map((item, index) => (
              <div class="relative pl-20">
                {index !== startup.timeline.length - 1 && (
                  <div class="absolute left-[24px] top-12 bottom-[-64px] w-0.5 bg-dashed border-l-2 border-dashed border-jade/30"></div>
                )}
                <div class="absolute left-0 top-0 w-12 h-12 rounded-2xl bg-jade flex items-center justify-center text-white font-black text-lg border-4 border-arena z-10 shadow-lg shadow-jade/20 font-display">
                  {item.step}
                </div>
                <h4 class="text-2xl font-bold font-display text-petroleo uppercase tracking-tight mb-2">{item.title}</h4>
                <span class="text-[10px] text-jade font-black uppercase tracking-[0.2em]">{item.date}</span>
                <p class="text-petroleo/60 mt-4 text-sm leading-relaxed font-medium">{item.description}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Evidence Gallery -->
        <div class="lg:col-span-7 text-left">
          <div class="mb-20">
            <h2 class="text-4xl font-bold font-display mb-6 text-petroleo uppercase tracking-tight">Evidencias & Operación</h2>
            <p class="text-petroleo/50 font-medium text-lg leading-relaxed">Documentación visual de nuestras actividades y producto.</p>
          </div>
          <div class="grid grid-cols-2 gap-8">
            {startup.evidence.map((item, index) => (
              <div class={`group relative overflow-hidden rounded-[40px] shadow-2xl border-8 border-white bg-white ${index === 2 ? "col-span-2 aspect-[21/9]" : "aspect-square md:aspect-auto md:h-[350px]"}`}>
                <img src={item.image} alt={item.title} class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" />
                <div class="absolute inset-0 bg-gradient-to-t from-petroleo via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-all duration-700 flex flex-col justify-end p-10 text-left">
                  <span class="text-jade text-[10px] font-black uppercase tracking-[0.3em] mb-2 translate-y-6 group-hover:translate-y-0 transition-transform duration-500">
                    {item.type}
                  </span>
                  <p class="text-white font-bold text-xl translate-y-6 group-hover:translate-y-0 transition-transform duration-500 delay-100 font-display uppercase tracking-tight">
                    {item.title}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </main>

  <script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    const init = () => {
      const main = document.getElementById("main-content");
      if (main) main.classList.remove("opacity-0");

      const reveals = document.querySelectorAll(".reveal");
      gsap.set(reveals, { clearProps: "all" });
      reveals.forEach((el) => {
        gsap.from(el, {
          scrollTrigger: {
            trigger: el,
            start: "top 85%",
            toggleActions: "play none none none"
          },
          opacity: 0,
          y: 40,
          duration: 0.8,
          ease: "power3.out"
        });
      });
    };

    document.addEventListener("astro:page-load", () => {
      ScrollTrigger.getAll().forEach(t => t.kill());
      init();
    });
  </script>
</Layout>
