---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getEvents } from "../../lib/cms";

const events = await getEvents();
---

<Layout title="Eventos | Nexis Oaxaca Tech">
  <Header />

  <main class="pt-32 pb-24 px-6 bg-marfil">
    <div class="max-w-7xl mx-auto">
      <div class="mb-20 text-left">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-jade/10 text-jade rounded-full text-xs font-bold uppercase tracking-widest mb-6 border border-jade/20">
          Agenda abierta
        </div>
        <h1 class="font-display text-6xl md:text-7xl font-extrabold text-petroleo leading-[1.05] tracking-tight mb-8 uppercase">
          Todos los <span class="text-jade">Eventos</span>
        </h1>
        <p class="text-xl text-petroleo/60 max-w-2xl leading-relaxed font-medium">
          Explora nuestra cartelera de actividades tecnológicas en Oaxaca.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {events.map((event) => (
          <a
            href={`/eventos/${event.slug}`}
            class="group bg-white rounded-4xl overflow-hidden border border-gris flex flex-col h-full shadow-sm hover:shadow-xl transition-shadow duration-300"
          >
            <div class="relative h-64 overflow-hidden">
              <img
                src={event.image}
                alt={event.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-linear-to-t from-black/60 via-transparent to-transparent"></div>
              <div class="absolute top-5 left-5">
                <span class="bg-jade text-white text-[10px] font-extrabold uppercase tracking-widest px-4 py-1.5 rounded-full shadow-lg">
                  {event.type || "Evento"}
                </span>
              </div>
              <div class="absolute bottom-5 left-5 text-white text-left">
                <span class="text-2xl font-bold font-display">
                  {new Date(event.date).getDate()}
                </span>
                <span class="text-[10px] font-bold uppercase block opacity-80 tracking-widest">
                  {new Date(event.date).toLocaleDateString("es-ES", {
                    month: "long",
                  })}
                </span>
              </div>
            </div>
            <div class="p-8 flex flex-col grow text-left">
              <h3 class="font-display text-2xl font-bold text-petroleo mb-4 group-hover:text-jade transition-colors">
                {event.title}
              </h3>
              <p class="text-petroleo/60 text-sm mb-8 line-clamp-2 leading-relaxed">
                {event.description}
              </p>
              <div class="mt-auto flex items-center justify-between text-petroleo/40">
                <span class="text-[10px] font-bold uppercase tracking-widest">
                  {event.location || "Oaxaca"}
                </span>
                <span class="text-[10px] font-bold text-jade uppercase tracking-widest">
                  Ver detalles
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>