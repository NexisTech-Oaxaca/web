---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import events from "../../data/events.json";
import { Search, SlidersHorizontal, Calendar, MapPin } from "lucide-astro";
---

<Layout title="Eventos | Nexis Oaxaca Tech">
  <Header />

  <main class="pt-32 pb-24 px-6 bg-marfil">
    <div class="max-w-7xl mx-auto">
      <div class="mb-20">
        <div
          class="inline-flex items-center gap-2 px-4 py-2 bg-jade/10 text-jade rounded-full text-xs font-bold uppercase tracking-widest mb-6 border border-jade/20"
        >
          Agenda 2026 Abierta
        </div>
        <h1
          class="font-display text-6xl md:text-7xl font-extrabold text-petroleo leading-[1.05] tracking-tight mb-8 uppercase"
        >
          Todos los <span class="text-jade">Eventos</span>
        </h1>
        <p
          class="text-xl text-petroleo/60 max-w-2xl leading-relaxed font-medium"
        >
          Explora nuestra cartelera de actividades tecnológicas en Oaxaca.
        </p>
      </div>

      <!-- Search & Filter Bar -->
      <!--
			<div class="sticky top-24 z-40 mb-16 py-4">
