---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getEventBySlug, getEvents } from "../../lib/cms";
import {
  ArrowLeft,
  MapPin,
  Calendar,
  ExternalLink,
  Youtube,
  Facebook,
  Instagram,
  Linkedin,
  Info,
} from "lucide-astro";

export async function getStaticPaths() {
  const events = await getEvents();

  return events.map((event) => ({
    params: { id: event.slug },
    props: { event },
  }));
}

const { event: staticEvent } = Astro.props;
const event = staticEvent ?? (await getEventBySlug(Astro.params.id || ""));

if (!event) {
  throw new Error(`Evento no encontrado: ${Astro.params.id}`);
}

const now = new Date();
now.setHours(0, 0, 0, 0);

const eventDate = new Date(`${event.date}T00:00:00`);
const isUpcoming = eventDate.getTime() >= now.getTime();

const getYoutubeEmbedUrl = (url?: string) => {
  if (!url) return "";
  const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
  const match = url.match(regExp);
  return match && match[2].length === 11 ? `https://www.youtube.com/embed/${match[2]}` : "";
};

const youtubeEmbedUrl = getYoutubeEmbedUrl(event.media?.youtube);
const hasMedia = Boolean(
  event.media &&
    (event.media.youtube ||
      event.media.facebook ||
      event.media.instagram ||
      event.media.linkedin),
);
const hasGallery = Boolean(event.gallery && event.gallery.length > 0);
const hasAnyEvidence = hasMedia || hasGallery || Boolean(youtubeEmbedUrl);

const getInitials = (name: string) =>
  name
    ? name
        .split(" ")
        .filter(Boolean)
        .map((word) => word[0])
        .join("")
        .slice(0, 2)
        .toUpperCase()
    : "NN";
---

<Layout title={`${event.title} | Nexis Oaxaca Tech`}>
  <Header />

  <main class="pt-32 pb-24 bg-marfil">
    <div class="max-w-7xl mx-auto px-6 space-y-24">
      <a
        href="/eventos"
        class="inline-flex items-center gap-2 text-petroleo/40 hover:text-jade font-bold text-xs uppercase tracking-widest transition-colors group"
      >
        <ArrowLeft class="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
        Volver a eventos
      </a>

      <section class="grid lg:grid-cols-12 gap-16 items-start">
        <div class="lg:col-span-7 space-y-8 text-left">
          <div
            class={`inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-widest ${isUpcoming ? "bg-jade/10 border border-jade/20 text-jade" : "bg-petroleo/10 border border-petroleo/20 text-petroleo/60"}`}
          >
            <span
              class={`w-2 h-2 rounded-full ${isUpcoming ? "bg-jade animate-pulse" : "bg-petroleo/40"}`}
            ></span>
            {isUpcoming ? "Próximo evento" : "Evento finalizado"}
          </div>

          <h1 class="text-3xl sm:text-4xl md:text-7xl font-display font-extrabold leading-[1.05] tracking-tight text-petroleo uppercase">
            {event.title}
          </h1>

          <p class="text-sm sm:text-base md:text-xl text-petroleo/70 max-w-2xl leading-relaxed">
            {event.description}
          </p>

          <div class="grid grid-cols-2 md:grid-cols-4 gap-6 p-8 bg-white rounded-4xl border border-petroleo/5 shadow-sm">
            <div class="space-y-1">
              <p class="text-[9px] font-bold text-petroleo/40 uppercase tracking-widest">Fecha</p>
              <p class="font-bold text-petroleo">{event.date}</p>
            </div>
            <div class="space-y-1">
              <p class="text-[9px] font-bold text-petroleo/40 uppercase tracking-widest">Hora</p>
              <p class="font-bold text-petroleo">{event.time || "17:00 CST"}</p>
            </div>
            <div class="space-y-1">
              <p class="text-[9px] font-bold text-petroleo/40 uppercase tracking-widest">Lugar</p>
              <p class="font-bold text-petroleo">{event.location || "Oaxaca"}</p>
            </div>
            <div class="space-y-1">
              <p class="text-[9px] font-bold text-petroleo/40 uppercase tracking-widest">Tipo</p>
              <span class="inline-block px-3 py-1 bg-ambar text-white text-[9px] font-black rounded-full uppercase tracking-widest">
                {event.type || "Evento"}
              </span>
            </div>
          </div>
        </div>

        <div class="lg:col-span-5">
          <div class="relative rounded-[40px] overflow-hidden shadow-2xl aspect-4/5 border-8 border-white">
            <img
              src={event.image}
              alt={event.title}
              class="w-full h-full object-cover"
              transition:name={`event-image-${event.slug}`}
            />
            <div class="absolute inset-0 bg-linear-to-t from-petroleo/80 via-transparent to-transparent opacity-60"></div>
            <div class="absolute bottom-8 left-8 right-8 text-left text-white">
              <div class="flex items-center gap-2 text-white/80 text-xs font-bold uppercase tracking-widest">
                <MapPin class="w-4 h-4 text-jade" />
                <span>{event.location || "Oaxaca de Juárez, México"}</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      {event.speakers && event.speakers.length > 0 && (
        <section class="space-y-8 text-left">
          <div class="border-b border-petroleo/10 pb-4">
            <h2 class="text-xs font-bold uppercase tracking-widest text-petroleo/40">Ponentes e invitados</h2>
          </div>
          <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
            {event.speakers.map((speaker) => {
              const hasRealImage = Boolean(speaker.image && !speaker.image.includes("placeholder"));

              return (
                <div class="bg-white rounded-4xl p-6 border border-petroleo/5 shadow-sm hover:border-jade/20 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group flex flex-col items-center text-center">
                  <div class="relative w-24 h-24 rounded-full overflow-hidden mb-4 border-4 border-marfil shadow-inner bg-petroleo/5 group-hover:scale-105 transition-transform duration-300">
                    {hasRealImage ? (
                      <img src={speaker.image} alt={speaker.name} class="w-full h-full object-cover" />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center bg-linear-to-br from-petroleo/5 to-petroleo/10 text-petroleo/40 text-2xl font-display font-extrabold uppercase">
                        {getInitials(speaker.name)}
                      </div>
                    )}
                  </div>
                  <h3 class="font-display font-bold text-petroleo group-hover:text-jade transition-colors duration-300 text-lg">
                    {speaker.name}
                  </h3>
                  {speaker.role && (
                    <p class="text-xs text-petroleo/50 font-bold uppercase tracking-widest mt-1">
                      {speaker.role}
                    </p>
                  )}
                </div>
              );
            })}
          </div>
        </section>
      )}

      <section class="bg-white rounded-[40px] p-8 md:p-16 shadow-2xl border border-petroleo/5 max-w-5xl mx-auto space-y-12">
        <div class="text-center space-y-2">
          <h3 class="text-3xl sm:text-4xl font-display font-bold text-petroleo uppercase">
            {isUpcoming ? "Agenda este evento" : "Evidencia y memorias"}
          </h3>
          <p class="text-petroleo/60 text-sm sm:text-base md:text-lg">
            {isUpcoming
              ? "Añádelo a tu calendario con un clic y sé parte de la comunidad."
              : "Revive los mejores momentos de este encuentro tecnológico."}
          </p>
        </div>

        {isUpcoming ? (
          <div class="text-center space-y-8">
            <div class="bg-arena/60 rounded-3xl p-8 max-w-lg mx-auto space-y-4 border border-petroleo/5">
              <div class="w-14 h-14 rounded-2xl bg-jade/10 flex items-center justify-center mx-auto">
                <Calendar class="w-7 h-7 text-jade" />
              </div>
              <div class="space-y-1">
                <p class="font-bold text-petroleo text-xl">No te lo pierdas</p>
                <p class="text-sm text-petroleo/60">
                  Agrega este evento a Google Calendar y recibe un recordatorio
                  automático para que no olvides asistir.
                </p>
              </div>
            </div>

            {event.registerLink ? (
              <a
                href={event.registerLink}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-3 bg-jade text-white px-10 py-5 rounded-[20px] font-bold text-lg hover:bg-petroleo transition-all shadow-xl shadow-jade/30 group"
              >
                <Calendar class="w-6 h-6" />
                Agregar a Google Calendar
                <ExternalLink class="w-5 h-5 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" />
              </a>
            ) : (
              <div class="py-4">
                <p class="text-petroleo/40 text-sm">Registro no disponible por el momento.</p>
                <p class="text-petroleo/30 text-xs mt-1">Sigue nuestras redes para conocer próximos eventos.</p>
              </div>
            )}
          </div>
        ) : (
          <div class="space-y-12">
            {youtubeEmbedUrl && (
              <div class="space-y-4">
                <h4 class="text-xs font-bold uppercase tracking-widest text-petroleo/40">Grabación del evento</h4>
                <div class="relative w-full aspect-video rounded-3xl overflow-hidden shadow-lg border border-petroleo/5 bg-black">
                  <iframe
                    class="w-full h-full border-0 absolute inset-0"
                    src={youtubeEmbedUrl}
                    title="YouTube video player"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                  ></iframe>
                </div>
              </div>
            )}

            {hasGallery && (
              <div class="space-y-4">
                <h4 class="text-xs font-bold uppercase tracking-widest text-petroleo/40">Galería de fotos</h4>
                <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                  {event.gallery!.map((imgUrl: string, idx: number) => (
                    <div class="relative overflow-hidden rounded-3xl aspect-video shadow-md bg-petroleo/5">
                      <img src={imgUrl} alt={`Evidencia ${idx + 1}`} class="w-full h-full object-cover" />
                      <div class="absolute inset-0 bg-linear-to-t from-petroleo/40 to-transparent"></div>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {hasMedia && (
              <div class="space-y-4 pt-6 border-t border-petroleo/10">
                <p class="text-xs font-bold uppercase tracking-widest text-petroleo/40 text-center">
                  El evento ya terminó, pero puedes verlo disponible en:
                </p>
                <div class="flex flex-wrap gap-4 justify-center">
                  {event.media?.youtube && (
                    <a href={event.media.youtube} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 px-5 py-3 rounded-xl border border-red-200 bg-red-50/50 hover:bg-red-50 text-red-600 transition-all font-sans text-xs font-bold tracking-wide">
                      <Youtube class="w-4 h-4" />
                      <span>YOUTUBE</span>
                    </a>
                  )}
                  {event.media?.facebook && (
                    <a href={event.media.facebook} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 px-5 py-3 rounded-xl border border-blue-200 bg-blue-50/50 hover:bg-blue-50 text-blue-600 transition-all font-sans text-xs font-bold tracking-wide">
                      <Facebook class="w-4 h-4" />
                      <span>FACEBOOK</span>
                    </a>
                  )}
                  {event.media?.instagram && (
                    <a href={event.media.instagram} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 px-5 py-3 rounded-xl border border-pink-200 bg-pink-50/50 hover:bg-pink-50 text-pink-600 transition-all font-sans text-xs font-bold tracking-wide">
                      <Instagram class="w-4 h-4" />
                      <span>INSTAGRAM</span>
                    </a>
                  )}
                  {event.media?.linkedin && (
                    <a href={event.media.linkedin} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 px-5 py-3 rounded-xl border border-sky-200 bg-sky-50/50 hover:bg-sky-50 text-sky-700 transition-all font-sans text-xs font-bold tracking-wide">
                      <Linkedin class="w-4 h-4" />
                      <span>LINKEDIN</span>
                    </a>
                  )}
                </div>
              </div>
            )}

            {!hasAnyEvidence && (
              <div class="flex flex-col items-center justify-center p-12 bg-red-50/30 border border-red-100 rounded-3xl text-center max-w-xl mx-auto space-y-4">
                <Info class="w-10 h-10 text-red-500" />
                <div>
                  <h4 class="font-bold text-petroleo text-lg">Evidencia no disponible</h4>
                  <p class="text-petroleo/60 text-sm mt-1">No hay evidencia adjunta para este evento.</p>
                </div>
              </div>
            )}
          </div>
        )}
      </section>
    </div>
  </main>

  <Footer />

  <script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    const init = () => {
      const reveals = document.querySelectorAll(".reveal");
      gsap.set(reveals, { clearProps: "all" });
      reveals.forEach((el) => {
        gsap.from(el, {
          scrollTrigger: {
            trigger: el,
            start: "top 85%",
            toggleActions: "play none none none",
          },
          opacity: 0,
          y: 30,
          duration: 0.8,
          ease: "power3.out",
        });
      });
    };

    document.addEventListener("astro:page-load", () => {
      ScrollTrigger.getAll().forEach((t) => t.kill());
      init();
    });
  </script>
</Layout>