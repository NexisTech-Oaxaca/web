---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import events from "../../data/events.json";
import {
  ArrowLeft,
  Calendar,
  MapPin,
  CheckCircle,
  Clock,
  Youtube,
  Facebook,
  Instagram,
  Linkedin,
  Twitter,
  Info,
  ChevronLeft,
  ChevronRight,
} from "lucide-astro";

export function getStaticPaths() {
  return events.map((event) => ({
    params: { id: event.id },
    props: { event },
  }));
}

const { event } = Astro.props;

// Determine if the event is upcoming or past relative to the current local time
const now = new Date();
now.setHours(0, 0, 0, 0);
const eventDate = new Date(event.date + "T00:00:00");
const isUpcoming = eventDate.getTime() >= now.getTime();

// Parse YouTube URL to get the embed ID
const getYoutubeEmbedUrl = (url?: string) => {
  if (!url) return "";
  const regExp =
    /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
  const match = url.match(regExp);
  return match && match[2].length === 11
    ? `https://www.youtube.com/embed/${match[2]}`
    : "";
};

const youtubeEmbedUrl = getYoutubeEmbedUrl(event.media?.youtube);

const hasMedia = !!(
  event.media &&
  (event.media.youtube ||
    event.media.facebook ||
    event.media.instagram ||
    event.media.linkedin)
);
const hasGallery = !!(
  (event.gallery || event.galery) &&
  (event.gallery || event.galery).length > 0
);
const hasAnyEvidence = hasMedia || hasGallery;

const getInitials = (name: string) => {
  return name
    ? name
        .split(" ")
        .filter(Boolean)
        .map((n) => n[0])
        .join("")
        .slice(0, 2)
        .toUpperCase()
    : "NN";
};
---

<Layout title={`${event.title} | Nexis Oaxaca Tech`}>
  <Header />

  <main class="pt-32 pb-24 bg-marfil">
    <div class="max-w-7xl mx-auto px-6">
      <a
        href="/eventos"
        class="inline-flex items-center gap-2 text-petroleo/40 hover:text-jade font-bold text-xs uppercase tracking-widest mb-12 transition-colors group"
      >
        <ArrowLeft
          class="w-4 h-4 group-hover:-translate-x-1 transition-transform"
        /> Volver a eventos
      </a>

      <div class="grid lg:grid-cols-12 gap-16 items-center mb-24">
        <div class="lg:col-span-7 space-y-8 text-left">
          <div
            class={`inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-widest ${isUpcoming ? "bg-jade/10 border border-jade/20 text-jade" : "bg-petroleo/10 border border-petroleo/20 text-petroleo/60"}`}
          >
            <span
              class={`w-2 h-2 rounded-full ${isUpcoming ? "bg-jade animate-pulse" : "bg-petroleo/40"}`}
            ></span>
            {isUpcoming ? "Próximo Evento Presencial" : "Evento Finalizado"}
          </div>

          <h1
            class="text-5xl md:text-7xl font-display font-extrabold leading-[1.05] tracking-tight text-petroleo uppercase"
            transition:name={`event-title-${event.id}`}
          >
            {event.title}
          </h1>

          <p
            class="text-lg md:text-xl text-petroleo/70 max-w-2xl leading-relaxed"
          >
            {event.description}
          </p>

          <div
            class="grid grid-cols-2 md:grid-cols-4 gap-6 p-8 bg-white rounded-[32px] border border-petroleo/5 shadow-sm"
          >
            <div class="space-y-1">
              <p
                class="text-[9px] font-bold text-petroleo/40 uppercase tracking-widest"
              >
                Fecha
              </p>
              <p class="font-bold text-petroleo">{event.date}</p>
            </div>
            <div class="space-y-1">
              <p
                class="text-[9px] font-bold text-petroleo/40 uppercase tracking-widest"
              >
                Hora
              </p>
              <p class="font-bold text-petroleo">{event.time || "17:00 CST"}</p>
            </div>
            <div class="space-y-1">
              <p
                class="text-[9px] font-bold text-petroleo/40 uppercase tracking-widest"
              >
                Lugar
              </p>
              <p class="font-bold text-petroleo">
                {event.location || "Oaxaca"}
              </p>
            </div>
            <div class="space-y-1">
              <p
                class="text-[9px] font-bold text-petroleo/40 uppercase tracking-widest"
              >
                Tipo
              </p>
              <span
                class="inline-block px-3 py-1 bg-ambar text-white text-[9px] font-black rounded-full uppercase tracking-widest"
                >{event.type}</span
              >
            </div>
          </div>
        </div>

        <div class="lg:col-span-5 relative">
          <div
            class="relative rounded-[40px] overflow-hidden shadow-2xl aspect-[4/5] border-8 border-white"
          >
            <img
              src={event.image}
              alt={event.title}
              class="w-full h-full object-cover"
              transition:name={`event-image-${event.id}`}
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-petroleo/80 via-transparent to-transparent opacity-60"
            >
            </div>
            <div class="absolute bottom-8 left-8 right-8 text-left">
              <div
                class="flex items-center gap-2 text-white/80 text-xs font-bold uppercase tracking-widest"
              >
                <MapPin class="w-4 h-4 text-jade" />
                <span>Oaxaca de Juárez, México</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      {
        event.speakers && event.speakers.length > 0 && (
          <div class="mb-24 space-y-8 text-left">
            <div class="border-b border-petroleo/10 pb-4">
              <h2 class="text-xs font-bold uppercase tracking-widest text-petroleo/40">
                Ponentes e Invitados
              </h2>
            </div>
            <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
              {event.speakers.map((speaker) => {
                const hasRealImage =
                  speaker.image &&
                  speaker.image !== "" &&
                  !speaker.image.includes("placeholder");
                return (
                  <div class="bg-white rounded-[32px] p-6 border border-petroleo/5 shadow-sm hover:border-jade/20 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group flex flex-col items-center text-center">
                    <div class="relative w-24 h-24 rounded-full overflow-hidden mb-4 border-4 border-marfil shadow-inner bg-petroleo/5 group-hover:scale-105 transition-transform duration-300">
                      {hasRealImage ? (
                        <img
                          src={speaker.image}
                          alt={speaker.name}
                          class="w-full h-full object-cover"
                        />
                      ) : (
                        <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-petroleo/5 to-petroleo/10 text-petroleo/40 text-2xl font-display font-extrabold uppercase">
                          {getInitials(speaker.name)}
                        </div>
                      )}
                    </div>
                    <h3 class="font-display font-bold text-petroleo group-hover:text-jade transition-colors duration-300 text-lg">
                      {speaker.name}
                    </h3>
                    {speaker.role && (
                      <p class="text-xs text-petroleo/50 font-bold uppercase tracking-widest mt-1">
                        {speaker.role}
                      </p>
                    )}
                  </div>
                );
              })}
            </div>
          </div>
        )
      }

      <!-- Dynamic Action Card: Registration Form or Evidence Recap -->
      {
        isUpcoming ? (
          <div class="bg-white rounded-[40px] p-8 md:p-16 shadow-2xl border border-petroleo/5 max-w-4xl mx-auto text-center reveal">
            <h3 class="text-4xl font-display font-bold mb-4 text-petroleo">
              Reserva tu lugar
            </h3>
            <p class="text-petroleo/60 mb-12 text-lg">
              Cupos presenciales limitados para garantizar la calidad del
              networking.
            </p>

            <form class="space-y-6 text-left">
              <div class="grid md:grid-cols-2 gap-6">
                <div class="space-y-2">
                  <label class="text-[10px] font-bold uppercase tracking-widest text-petroleo/40 ml-4">
                    Nombre Completo
                  </label>
                  <input
                    type="text"
                    placeholder="Ej. Alejandro Ruiz"
                    class="w-full bg-arena/50 border border-gris rounded-[20px] px-6 py-4 focus:border-jade outline-none transition-all font-medium text-petroleo"
                  />
                </div>
                <div class="space-y-2">
                  <label class="text-[10px] font-bold uppercase tracking-widest text-petroleo/40 ml-4">
                    Email de contacto
                  </label>
                  <input
                    type="email"
                    placeholder="email@ejemplo.com"
                    class="w-full bg-arena/50 border border-gris rounded-[20px] px-6 py-4 focus:border-jade outline-none transition-all font-medium text-petroleo"
                  />
                </div>
              </div>
              <div class="space-y-2">
                <label class="text-[10px] font-bold uppercase tracking-widest text-petroleo/40 ml-4">
                  LinkedIn Profile (Opcional)
                </label>
                <input
                  type="url"
                  placeholder="https://linkedin.com/in/usuario"
                  class="w-full bg-arena/50 border border-gris rounded-[20px] px-6 py-4 focus:border-jade outline-none transition-all font-medium text-petroleo"
                />
              </div>
              <button
                type="submit"
                class="w-full bg-jade text-white py-6 rounded-[20px] font-bold text-xl hover:bg-petroleo transition-all shadow-xl shadow-jade/20 flex items-center justify-center gap-3 group mt-4"
              >
                Confirmar mi Registro{" "}
                <CheckCircle class="w-6 h-6 group-hover:scale-110 transition-transform" />
              </button>
            </form>
          </div>
        ) : (
          <div class="bg-white rounded-[40px] p-8 md:p-16 shadow-2xl border border-petroleo/5 max-w-4xl mx-auto reveal space-y-12">
            <div class="text-center space-y-2">
              <h3 class="text-4xl font-display font-bold text-petroleo uppercase">
                Evidencia y Memorias
              </h3>
              <p class="text-petroleo/60 text-lg">
                Revive los mejores momentos de este encuentro tecnológico.
              </p>
            </div>

            {/* 1. YouTube Video Preview */}
            {youtubeEmbedUrl && (
              <div class="space-y-4">
                <h4 class="text-xs font-bold uppercase tracking-widest text-petroleo/40">
                  Grabación del Evento
                </h4>
                <div class="relative w-full aspect-video rounded-3xl overflow-hidden shadow-lg border border-petroleo/5 bg-black">
                  <iframe
                    class="w-full h-full border-0 absolute inset-0"
                    src={youtubeEmbedUrl}
                    title="YouTube video player"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                  ></iframe>
                </div>
              </div>
            )}

            {/* 2. Carousel of Evidence Images */}
            {hasGallery && (
              <div class="space-y-4">
                <h4 class="text-xs font-bold uppercase tracking-widest text-petroleo/40">
                  Galería de Fotos
                </h4>
                <div class="relative w-full aspect-[16/9] rounded-3xl overflow-hidden border border-petroleo/5 shadow-md bg-petroleo/5 group/carousel">
                  <div
                    id="carousel-slides"
                    class="flex w-full h-full transition-transform duration-500 ease-out"
                  >
                    {(event.gallery || event.galery)?.map((imgUrl, idx) => (
                      <div class="min-w-full h-full relative flex-shrink-0">
                        <img
                          src={imgUrl}
                          alt={`Evidencia ${idx + 1}`}
                          class="w-full h-full object-cover"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-petroleo/40 to-transparent" />
                      </div>
                    ))}
                  </div>

                  <button
                    id="prev-slide"
                    class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/90 hover:bg-white text-petroleo flex items-center justify-center shadow-lg transition-all hover:scale-105 cursor-pointer z-10"
                  >
                    <ChevronLeft class="w-6 h-6" />
                  </button>
                  <button
                    id="next-slide"
                    class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/90 hover:bg-white text-petroleo flex items-center justify-center shadow-lg transition-all hover:scale-105 cursor-pointer z-10"
                  >
                    <ChevronRight class="w-6 h-6" />
                  </button>

                  <div class="absolute bottom-6 left-6 bg-petroleo/80 backdrop-blur-md text-white text-[10px] font-bold uppercase tracking-widest px-4 py-2 rounded-full z-10">
                    Fotos del Evento
                  </div>
                </div>
              </div>
            )}

            {/* 3. Social Media Links */}
            {hasMedia && (
              <div class="space-y-4 pt-6 border-t border-petroleo/10">
                <p class="text-xs font-bold uppercase tracking-widest text-petroleo/40 text-center">
                  El evento ya terminó, pero podrás verlo disponible en:
                </p>
                <div class="flex flex-wrap gap-4 justify-center">
                  {event.media?.youtube && (
                    <a
                      href={event.media.youtube}
                      target="_blank"
                      class="inline-flex items-center gap-2 px-5 py-3 rounded-xl border border-red-200 bg-red-50/50 hover:bg-red-50 text-red-600 transition-all font-sans text-xs font-bold tracking-wide"
                    >
                      <Youtube class="w-4 h-4" />
                      <span>YOUTUBE</span>
                    </a>
                  )}
                  {event.media?.facebook && (
                    <a
                      href={event.media.facebook}
                      target="_blank"
                      class="inline-flex items-center gap-2 px-5 py-3 rounded-xl border border-blue-200 bg-blue-50/50 hover:bg-blue-50 text-blue-600 transition-all font-sans text-xs font-bold tracking-wide"
                    >
                      <Facebook class="w-4 h-4" />
                      <span>FACEBOOK</span>
                    </a>
                  )}
                  {event.media?.instagram && (
                    <a
                      href={event.media.instagram}
                      target="_blank"
                      class="inline-flex items-center gap-2 px-5 py-3 rounded-xl border border-pink-200 bg-pink-50/50 hover:bg-pink-50 text-pink-600 transition-all font-sans text-xs font-bold tracking-wide"
                    >
                      <Instagram class="w-4 h-4" />
                      <span>INSTAGRAM</span>
                    </a>
                  )}
                  {event.media?.linkedin && (
                    <a
                      href={event.media.linkedin}
                      target="_blank"
                      class="inline-flex items-center gap-2 px-5 py-3 rounded-xl border border-sky-200 bg-sky-50/50 hover:bg-sky-50 text-sky-700 transition-all font-sans text-xs font-bold tracking-wide"
                    >
                      <Linkedin class="w-4 h-4" />
                      <span>LINKEDIN</span>
                    </a>
                  )}
                </div>
              </div>
            )}

            {/* 4. Fallback banner if absolutely NO evidence */}
            {!hasAnyEvidence && (
              <div class="flex flex-col items-center justify-center p-12 bg-red-50/30 border border-red-100 rounded-3xl text-center max-w-xl mx-auto space-y-4">
                <Info class="w-10 h-10 text-red-500" />
                <div>
                  <h4 class="font-bold text-petroleo text-lg">
                    Evidencia no disponible
                  </h4>
                  <p class="text-petroleo/60 text-sm mt-1">
                    No hay evidencia adjunta para este evento
                  </p>
                </div>
              </div>
            )}
          </div>
        )
      }
    </div>
  </main>

  <Footer />

  <script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    const init = () => {
      const reveals = document.querySelectorAll(".reveal");
      gsap.set(reveals, { clearProps: "all" });
      reveals.forEach((el) => {
        gsap.from(el, {
          scrollTrigger: {
            trigger: el,
            start: "top 85%",
            toggleActions: "play none none none",
          },
          opacity: 0,
          y: 30,
          duration: 0.8,
          ease: "power3.out",
        });
      });

      // CSS Carousel Logic
      let currentIdx = 0;
      const slidesContainer = document.getElementById("carousel-slides");
      const prevBtn = document.getElementById("prev-slide");
      const nextBtn = document.getElementById("next-slide");

      if (slidesContainer && prevBtn && nextBtn) {
        const totalSlides = slidesContainer.children.length;

        const updateSlide = () => {
          slidesContainer.style.transform = `translateX(-${currentIdx * 100}%)`;
        };

        prevBtn.addEventListener("click", () => {
          currentIdx = (currentIdx - 1 + totalSlides) % totalSlides;
          updateSlide();
        });

        nextBtn.addEventListener("click", () => {
          currentIdx = (currentIdx + 1) % totalSlides;
          updateSlide();
        });
      }
    };

    document.addEventListener("astro:page-load", () => {
      ScrollTrigger.getAll().forEach(t => t.kill());
      init();
    });
  </script>
</Layout>
