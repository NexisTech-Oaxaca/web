---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { ArrowLeft, CheckCircle2, Send, LoaderCircle, MapPin, Briefcase, Lightbulb, User, Mail } from 'lucide-astro';

const dedicaciones = [
  { value: 'estudiante', label: 'Estudiante' },
  { value: 'profesor', label: 'Profesor / Docente' },
  { value: 'cloud', label: 'Cloud / Infraestructura' },
  { value: 'software', label: 'Desarrollo de Software' },
  { value: 'ia', label: 'Inteligencia Artificial' },
  { value: 'diseno', label: 'Diseño / UX' },
  { value: 'datos', label: 'Datos / Analytics' },
  { value: 'cybersecurity', label: 'Ciberseguridad' },
  { value: 'devops', label: 'DevOps / SRE' },
  { value: 'emprendedor', label: 'Emprendedor' },
  { value: 'otro', label: 'Otro' },
];
---

<Layout title="Ingreso a miembros | Nexis Oaxaca Tech">
  <Header />

  <main class="pt-32 pb-24 px-6 bg-marfil min-h-screen">
    <div class="max-w-2xl mx-auto">
      <a href="/" class="inline-flex items-center gap-2 text-petroleo/50 hover:text-petroleo transition-colors mb-12 text-sm font-medium group">
        <ArrowLeft class="w-4 h-4 transition-transform group-hover:-translate-x-1" />
        Volver al inicio
      </a>

      <div class="rounded-[40px] border-2 border-petroleo/10 bg-white shadow-sm overflow-hidden">
        <div class="p-6 sm:p-10 pb-6 sm:pb-8 border-b border-petroleo/5">
          <h1 class="font-display text-3xl sm:text-4xl font-bold text-petroleo mb-3">Únete a Nexis Oaxaca</h1>
          <p class="text-petroleo/60 text-base sm:text-lg">
            Forma parte de la comunidad tecnológica más vibrante de Oaxaca.
          </p>
        </div>

        <div class="p-6 sm:p-10">
          <div id="form-container">
            <form id="ingreso-form" class="space-y-6">

              <div>
                <label for="nombre" class="block text-sm font-bold text-petroleo mb-2.5 uppercase tracking-wider">
                  <span class="inline-flex items-center gap-2.5">
                    <User class="w-5 h-5 text-petroleo/70 shrink-0" />
                    Nombre completo
                  </span>
                </label>
                <input
                  type="text" id="nombre" name="nombre" required
                  class="w-full px-5 py-4 rounded-2xl border-2 border-petroleo/10 bg-marfil text-petroleo placeholder:text-petroleo/30 focus:outline-none transition-all duration-300"
                  placeholder="Tu nombre completo"
                />
                <p class="text-red-500 text-xs mt-1 hidden" id="error-nombre">Este campo es obligatorio</p>
              </div>

              <div>
                <label for="email" class="block text-sm font-bold text-petroleo mb-2.5 uppercase tracking-wider">
                  <span class="inline-flex items-center gap-2.5">
                    <Mail class="w-5 h-5 text-petroleo/70 shrink-0" />
                    Correo electrónico
                  </span>
                </label>
                <input
                  type="email" id="email" name="email" required
                  class="w-full px-5 py-4 rounded-2xl border-2 border-petroleo/10 bg-marfil text-petroleo placeholder:text-petroleo/30 focus:outline-none transition-all duration-300"
                  placeholder="tu@correo.com"
                />
                <p class="text-red-500 text-xs mt-1 hidden" id="error-email">Ingresa un email válido</p>
              </div>

              <div>
                <label for="procedencia" class="block text-sm font-bold text-petroleo mb-2.5 uppercase tracking-wider">
                  <span class="inline-flex items-center gap-2.5">
                    <MapPin class="w-5 h-5 text-petroleo/70 shrink-0" />
                    ¿De qué parte de Oaxaca eres?
                  </span>
                </label>
                <input
                  type="text" id="procedencia" name="procedencia" required
                  class="w-full px-5 py-4 rounded-2xl border-2 border-petroleo/10 bg-marfil text-petroleo placeholder:text-petroleo/30 focus:outline-none transition-all duration-300"
                  placeholder="Ej. Oaxaca de Juárez, Puerto Escondido, Tuxtepec..."
                />
                <p class="text-red-500 text-xs mt-1 hidden" id="error-procedencia">Este campo es obligatorio</p>
              </div>

              <div>
                <label for="dedicacion" class="block text-sm font-bold text-petroleo mb-2.5 uppercase tracking-wider">
                  <span class="inline-flex items-center gap-2.5">
                    <Briefcase class="w-5 h-5 text-petroleo/70 shrink-0" />
                    ¿A qué te dedicas?
                  </span>
                </label>
                <div class="relative">
                  <select
                    id="dedicacion" name="dedicacion" required
                    class="w-full px-5 py-4 rounded-2xl border-2 border-petroleo/10 bg-marfil text-petroleo focus:outline-none transition-all duration-300 appearance-none pr-12"
                  >
                  <option value="" disabled selected>Selecciona una opción</option>
                  {dedicaciones.map(d => (
                    <option value={d.value}>{d.label}</option>
                  ))}
                </select>
                  <svg class="pointer-events-none absolute right-5 top-1/2 -translate-y-1/2 w-5 h-5 text-petroleo/50" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                </div>
                <p class="text-red-500 text-xs mt-1 hidden" id="error-dedicacion">Selecciona una opción</p>
              </div>

              <div>
                <label for="proyecto" class="block text-sm font-bold text-petroleo mb-2.5 uppercase tracking-wider">
                  <span class="inline-flex items-center gap-2.5">
                    <Lightbulb class="w-5 h-5 text-petroleo/70 shrink-0" />
                    ¿Te gustaría promocionar algún proyecto o emprendimiento en nuestro sitio web?
                  </span>
                </label>
                <textarea
                  id="proyecto" name="proyecto" rows={3}
                  class="w-full px-5 py-4 rounded-2xl border-2 border-petroleo/10 bg-marfil text-petroleo placeholder:text-petroleo/30 focus:outline-none transition-all duration-300 resize-none"
                  placeholder="Cuéntanos brevemente de qué se trata (opcional)"
                ></textarea>
              </div>

              <button
                type="submit" id="submit-btn"
                class="submit-btn relative w-full py-5 rounded-2xl font-bold text-lg flex items-center justify-center gap-3 overflow-hidden transition-all duration-500 disabled:cursor-not-allowed"
                style="--btn-bg: #234A57; --btn-text: white; --btn-bg-hover: #1d3d48; --btn-shadow: rgba(35,74,87,0.3)"
              >
                <span class="absolute inset-0 opacity-0 transition-opacity duration-500" id="btn-bg-glow"></span>
                <span id="btn-text" class="relative z-10">Unirme a la comunidad</span>
                <span id="btn-icon" class="relative z-10"><Send class="w-5 h-5 transition-transform duration-300" /></span>
                <span id="btn-spinner" class="relative z-10 hidden"><LoaderCircle class="w-5 h-5 animate-spin" /></span>
                <span id="btn-check" class="relative z-10 hidden"><CheckCircle2 class="w-5 h-5" /></span>
              </button>

              <p class="text-center text-[10px] text-petroleo/30 leading-relaxed mt-4">
                Este sitio está protegido con Cloudflare Turnstile y se rige por la
                <a href="https://www.cloudflare.com/en-gb/turnstile-privacy-policy/" target="_blank" rel="noopener noreferrer" class="underline hover:text-petroleo/50 transition-colors">Política de Privacidad</a>
                y los
                <a href="https://www.cloudflare.com/en-gb/website-terms/" target="_blank" rel="noopener noreferrer" class="underline hover:text-petroleo/50 transition-colors">Términos del Servicio</a>
                de Cloudflare.
              </p>

              <div class="cf-turnstile" data-sitekey="0x4AAAAAAD6uLyml5OaSHsGS" id="turnstile-widget"></div>
            </form>

            <div id="success-message" class="hidden text-center py-12">
              <div class="w-20 h-20 rounded-full bg-jade/10 flex items-center justify-center mx-auto mb-6">
                <CheckCircle2 class="w-10 h-10 text-jade" />
              </div>
              <h2 class="font-display text-3xl font-bold text-petroleo mb-4">¡Ya eres miembro de Nexis Oaxaca!</h2>
              <p class="text-petroleo/60 text-lg mb-2">Revisa tu correo para acceder al grupo de WhatsApp.</p>
              <p class="text-petroleo/40 text-sm mb-8">Te hemos enviado un mensaje con todos los detalles para que te conectes con la comunidad.</p>
              <a href="/" class="inline-block bg-jade text-white px-10 py-4 rounded-2xl font-bold hover:bg-jade/90 transition-colors">
                Volver al inicio
              </a>
            </div>

            <div id="error-message" class="hidden mt-6 p-5 rounded-2xl bg-red-50 border border-red-200 text-red-700 text-sm">
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .submit-btn {
    background: var(--btn-bg);
    color: var(--btn-text);
    box-shadow: 0 4px 14px var(--btn-shadow);
  }
  .submit-btn:not(:disabled):hover {
    background: var(--btn-bg-hover);
    box-shadow: 0 6px 24px var(--btn-shadow);
  }
  .submit-btn:not(:disabled):active {
    transform: scale(0.97);
  }
  .submit-btn #btn-bg-glow {
    background: radial-gradient(circle at center, rgba(255,255,255,0.25), transparent 70%);
  }
  .submit-btn:not(:disabled):hover #btn-bg-glow {
    opacity: 1;
  }
</style>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  import { animate, spring, stagger } from 'motion';

  function safeAnimate(el: unknown, ...args: Parameters<typeof animate>) {
    if (!el) return;
    try { animate(el as any, ...args); } catch {}
  }

  function initIngresoForm() {
    const form = document.getElementById('ingreso-form') as HTMLFormElement | null;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
    const btnBgGlow = document.getElementById('btn-bg-glow') as HTMLSpanElement | null;
    const btnText = document.getElementById('btn-text') as HTMLSpanElement | null;
    const btnIcon = document.getElementById('btn-icon') as HTMLSpanElement | null;
    const btnSpinner = document.getElementById('btn-spinner') as HTMLSpanElement | null;
    const btnCheck = document.getElementById('btn-check') as HTMLSpanElement | null;
    const successMsg = document.getElementById('success-message') as HTMLDivElement | null;
    const errorMsg = document.getElementById('error-message') as HTMLDivElement | null;
    const formContainer = document.getElementById('form-container') as HTMLDivElement | null;
    const turnstileWidget = document.getElementById('turnstile-widget') as HTMLDivElement | null;

    if (!form || !submitBtn) return;

    const validators: Record<string, (value: string) => boolean> = {
      nombre: (v) => v.trim().length > 0,
      email: (v) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v),
      procedencia: (v) => v.trim().length > 0,
      dedicacion: (v) => v.trim().length > 0,
    };

    const errorEls: Record<string, HTMLElement | null> = {
      nombre: document.getElementById('error-nombre'),
      email: document.getElementById('error-email'),
      procedencia: document.getElementById('error-procedencia'),
      dedicacion: document.getElementById('error-dedicacion'),
    };

    let dotsInterval: ReturnType<typeof setInterval>;
    let submitting = false;

    function showFieldError(name: string) {
      const input = form.elements.namedItem(name) as HTMLElement | null;
      input?.classList.add('border-red-400', 'bg-red-50');
      const el = errorEls[name];
      if (el) {
        safeAnimate(el, { opacity: [0, 1], y: [-4, 0] }, { duration: 0.2 });
        el.classList.remove('hidden');
      }
    }

    function clearFieldError(name: string) {
      const input = form.elements.namedItem(name) as HTMLElement | null;
      input?.classList.remove('border-red-400', 'bg-red-50');
      errorEls[name]?.classList.add('hidden');
    }

    function setLoading(loading: boolean) {
      submitBtn.disabled = loading;
      if (loading) {
        if (btnText) btnText.textContent = 'Registrando';
        btnIcon?.classList.add('hidden');
        btnSpinner?.classList.remove('hidden');
        safeAnimate(btnText, { opacity: [1, 0.6] }, { duration: 0.15 });
      } else {
        if (btnText) btnText.textContent = 'Unirme a la comunidad';
        btnIcon?.classList.remove('hidden');
        btnSpinner?.classList.add('hidden');
        btnCheck?.classList.add('hidden');
        btnBgGlow?.classList.add('hidden');
        safeAnimate(btnText, { opacity: [0.6, 1] }, { duration: 0.15 });
      }
    }

    function animateLoadingDots(baseText: string) {
      let count = 0;
      dotsInterval = setInterval(() => {
        count = (count + 1) % 4;
        if (btnText) btnText.textContent = baseText + '.'.repeat(count);
      }, 400);
    }

    function getTurnstileToken(): string {
      const input = document.querySelector('[name="cf-turnstile-response"]') as HTMLInputElement | null;
      return input?.value || '';
    }

    function resetTurnstile() {
      if (typeof turnstile !== 'undefined' && turnstileWidget) {
        try { turnstile.reset(turnstileWidget); } catch {}
      }
    }

    submitBtn.addEventListener('mouseenter', () => {
      if (!submitBtn.disabled) {
        safeAnimate(submitBtn, { scale: 1.02 }, { type: 'spring', stiffness: 350, damping: 15 });
      }
    });

    submitBtn.addEventListener('mouseleave', () => {
      if (!submitBtn.disabled) {
        safeAnimate(submitBtn, { scale: 1 }, { type: 'spring', stiffness: 350, damping: 15 });
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (submitting) return;
      if (submitBtn.disabled) return;

      errorMsg?.classList.add('hidden');

      const data = new FormData(form);
      const nombre = (data.get('nombre') as string) || '';
      const email = (data.get('email') as string) || '';
      const procedencia = (data.get('procedencia') as string) || '';
      const dedicacion = (data.get('dedicacion') as string) || '';
      const proyecto = (data.get('proyecto') as string) || '';

      let hasErrors = false;
      for (const [field, validate] of Object.entries(validators)) {
        const value = data.get(field) as string;
        if (!validate(value || '')) {
          showFieldError(field);
          hasErrors = true;
        } else {
          clearFieldError(field);
        }
      }
      if (hasErrors) {
        safeAnimate(submitBtn, { x: [0, -6, 6, -4, 4, 0] }, { duration: 0.4, easing: spring() });
        return;
      }

      const turnstileToken = getTurnstileToken();

      if (!turnstileToken && typeof turnstile !== 'undefined' && turnstileWidget) {
        try {
          turnstile.execute(turnstileWidget);
          await new Promise<void>((resolve) => {
            const checkToken = setInterval(() => {
              const token = getTurnstileToken();
              if (token) { clearInterval(checkToken); resolve(); }
            }, 100);
            setTimeout(() => { clearInterval(checkToken); resolve(); }, 8000);
          });
        } catch {}
      }

      const finalToken = getTurnstileToken();

      if (!finalToken) {
        if (errorMsg) {
          errorMsg.textContent = 'Error de verificación anti-bot. Intenta de nuevo.';
          errorMsg.classList.remove('hidden');
          safeAnimate(errorMsg, { opacity: [0, 1], y: [-10, 0] }, { duration: 0.3 });
        }
        return;
      }

      submitting = true;
      setLoading(true);
      animateLoadingDots('Registrando');

      try {
        const res = await fetch('/api/ingreso', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ nombre, email, procedencia, dedicacion, proyecto, 'cf-turnstile-response': finalToken }),
        });

        const json = await res.json();

        if (!res.ok) {
          throw new Error(json.error || 'Error al registrar');
        }

        clearInterval(dotsInterval);
        if (btnText) btnText.textContent = '¡Registrado!';
        btnSpinner?.classList.add('hidden');
        btnCheck?.classList.remove('hidden');
        btnBgGlow?.classList.remove('hidden');

        try {
          await animate(
            submitBtn,
            { scale: [1, 1.05, 1] },
            { duration: 0.6, easing: spring({ stiffness: 250, damping: 10 }) },
          ).finished;
        } catch {}

        setTimeout(() => {
          try {
            animate(formContainer, { opacity: [1, 0], scale: [1, 0.95] }, { duration: 0.3 }).then(() => {
              formContainer?.classList.add('hidden');
              successMsg?.classList.remove('hidden');
              if (successMsg) {
                animate(
                  successMsg.querySelectorAll('*'),
                  { opacity: [0, 1], y: [20, 0] },
                  { duration: 0.4, delay: stagger(0.08), easing: spring() },
                );
              }
            });
          } catch {}
        }, 800);
      } catch (err) {
        clearInterval(dotsInterval);
        setLoading(false);
        resetTurnstile();

        if (errorMsg) {
          errorMsg.textContent = err instanceof Error ? err.message : 'Error de conexión';
          errorMsg.classList.remove('hidden');
          safeAnimate(errorMsg, { opacity: [0, 1], y: [-10, 0] }, { duration: 0.3 });
        }

        safeAnimate(submitBtn, { x: [0, -8, 8, -5, 5, 0] }, { duration: 0.5, easing: spring() });
      } finally {
        submitting = false;
      }
    });

    (['nombre', 'email', 'procedencia', 'dedicacion'] as const).forEach((field) => {
      const input = form.elements.namedItem(field) as HTMLElement | null;
      input?.addEventListener('input', () => clearFieldError(field));
      input?.addEventListener('change', () => clearFieldError(field));
      input?.addEventListener('focus', () => {
        safeAnimate(input, { scale: [1, 1.01] }, { duration: 0.15 });
      });
      input?.addEventListener('blur', () => {
        safeAnimate(input, { scale: [1.01, 1] }, { duration: 0.15 });
      });
    });
  }

  document.addEventListener('astro:page-load', initIngresoForm);
</script>
